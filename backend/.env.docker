# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/plagiarism_db

# Security
SECRET_KEY=replace-with-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Seeded admin account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisAdminPassword123!
CREATE_SAMPLE_USERS=false

# Storage
# Set to `s3` for MinIO/S3 or `local` for local filesystem.
STORAGE_TYPE=s3
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=plagiarism-uploads

# AI Detection
USE_EXTERNAL_AI_DETECTION=false
OPENAI_API_KEY=
TOGETHER_API_KEY=

# Celery & Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Environment
ENVIRONMENT=production
